# === Font ===
font-family = JetBrains Mono
font-family = Sarasa Term K
font-size = 14
font-thicken = true
font-synthetic-style = bold,italic,bold-italic

# === Theme ===
theme = Catppuccin Mocha

# === Cursor ===
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor, sudo, no-title

# === Korean text rendering ===
adjust-cell-height = 15%
adjust-cell-width = 0%
adjust-font-baseline = -2%
grapheme-width-method = unicode

# === Window ===
window-padding-x = 8
window-padding-y = 4
window-padding-balance = true
window-save-state = always
window-colorspace = display-p3
macos-titlebar-style = tabs
macos-option-as-alt = true
confirm-close-surface = false
background-opacity = 1

# === Mouse ===
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2

# === Clipboard ===
copy-on-select = clipboard
clipboard-paste-protection = false

# === Keybindings ===
keybind = cmd+s>r=reload_config
keybind = cmd+s>x=close_surface
keybind = cmd+s>n=new_window
keybind = cmd+s>c=new_tab
keybind = cmd+s>shift+l=next_tab
keybind = super+d=unbind
